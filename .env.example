# ============================================
# Jarvis V1 - Environment Configuration
# ============================================
# Copia este archivo como .env y completa los valores

# DeepSeek API
DEEPSEEK_API_KEY=sk-your-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Embedding Model (sentence-transformers)
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# Database Paths
DATABASE_PATH=data/profile/jarvis.db
CHROMA_EPISODIC_PATH=data/episodic
CHROMA_KNOWLEDGE_PATH=data/knowledge/vectors
SKILLS_PATH=data/skills
KNOWLEDGE_DOCS_PATH=data/knowledge/documents

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/jarvis.log

# Server
HOST=0.0.0.0
PORT=8000

# Brain Settings
MAX_SESSION_HISTORY=10
CONTEXT_MAX_MEMORIES=5
CONTEXT_MAX_DOCUMENTS=3
